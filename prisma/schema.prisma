// РусКрипто — схема БД криптобиржи (SQLite для демо)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  phone         String?
  passwordHash  String?
  referralCode  String?
  kycLevel      Int      @default(0) // 0=guest, 1=L1 doc, 2=L2 full
  kycStatus     String   @default("UNINITIATED") // UNINITIATED|PHONE_VERIFIED|DOC_VERIFIED|SELFIE_VERIFIED|ACTIVE
  qualified     Boolean  @default(false) // квалифицированный инвестор
  role          String   @default("USER") // USER|COMPLIANCE|ADMIN|FINANCE|BANK
  bankId        String?  // для роли BANK — привязка к конкретному банку
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  balances      Balance[]
  orders        Order[]
  trades        Trade[]
  transactions  Transaction[]
  p2pOffers     P2POffer[]
  p2pDeals      P2PDeal[]   @relation("dealBuyer")
  bank             Bank?    @relation(fields: [bankId], references: [id])
  payments      CrossBorderPayment[]
  alerts        ComplianceAlert[]  @relation("alertReviewer")
  loginEvents   LoginEvent[]
  referrals     Referral[]
}

model Balance {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset   String // RUB, USDT, BTC, ETH...
  amount  Float @default(0)
  locked  Float @default(0) // зарезервировано в ордерах

  @@unique([userId, asset])
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pair          String   // BTC/RUB
  side          String   // buy|sell
  type          String   // limit|market
  price         Float?
  quantity      Float
  filledQty     Float    @default(0)
  status        String   @default("OPEN") // OPEN|FILLED|CANCELLED|PARTIAL
  clientOrderId String?  // idempotency key
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trades        Trade[]
}

model Trade {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pair      String
  side      String
  price     Float
  quantity  Float
  total     Float
  fee       Float    @default(0)
  createdAt DateTime @default(now())
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // deposit|withdrawal|trade|fee
  asset     String
  amount    Float
  status    String   @default("COMPLETED") // PENDING|COMPLETED|FAILED
  address   String?
  txHash    String?
  createdAt DateTime @default(now())
}

model P2POffer {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // buy|sell
  asset     String   // USDT
  fiat      String   @default("RUB")
  price     Float
  amount    Float
  method    String   // СБП|Тинькофф|Сбер
  minLimit  Float    @default(1000)
  maxLimit  Float    @default(200000)
  completed Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  deals     P2PDeal[]
}

model P2PDeal {
  id            String   @id @default(cuid())
  offerId       String
  offer         P2POffer @relation(fields: [offerId], references: [id])
  buyerId       String
  buyer         User     @relation("dealBuyer", fields: [buyerId], references: [id])
  asset         String
  amount        Float
  price         Float
  total         Float
  paymentMethod String
  status        String   @default("PENDING") // PENDING|PAID|COMPLETED|CANCELLED|DISPUTE
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CrossBorderPayment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  corridor    String   // RU-CN|RU-AE|RU-TR|RU-IN
  fromCurrency String  // RUB
  toCurrency   String  // CNY
  amount       Float
  receiveAmount Float
  fee          Float
  rate         Float
  beneficiary  String
  purpose      String
  status       String   @default("INITIATED") // INITIATED|CC_PENDING|LIQUIDITY|CONVERTING|SENDING|SETTLED|FAILED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ComplianceAlert {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation("alertReviewer", fields: [userId], references: [id])
  type        String   // VELOCITY|THRESHOLD|SANCTION|PATTERN|STRUCTURING
  severity    String   @default("MEDIUM") // LOW|MEDIUM|HIGH|CRITICAL
  riskScore   Float    @default(0)
  description String
  entityType  String   // transaction|withdrawal|deposit|user
  entityId    String?
  status      String   @default("OPEN") // OPEN|REVIEWING|APPROVED|REJECTED|ESCALATED|SAR
  reviewerId  String?
  reviewedAt  DateTime?
  ruleId      String?
  createdAt   DateTime @default(now())
}

model KycDocument {
  id        String   @id @default(cuid())
  userId    String
  docType   String   // passport|driver_license|id_card
  status    String   @default("PENDING") // PENDING|VERIFIED|REJECTED
  createdAt DateTime @default(now())
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String
  device    String   // Chrome / iPhone / Firefox
  browser   String
  location  String   // "Москва, РФ"
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Referral {
  id            String   @id @default(cuid())
  code          String   // referrer's code (multiple referrals share same code)
  referrerId    String
  referrer      User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referredEmail String
  reward        Float    @default(0)
  status        String   @default("REGISTERED") // REGISTERED|VERIFIED|REWARDED
  createdAt     DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════════════
// Финансовый модуль: банки-партнёры, комиссии, лимиты, счета, свёрка
// ═══════════════════════════════════════════════════════════════════════

model Bank {
  id                  String   @id @default(cuid())
  name                String   // "ВТБ", "Альфа-Банк"
  bic                 String   @unique // БИК
  swift               String?  // SWIFT код
  inn                 String?  // ИНН
  correspondentAccount String? // Корр. счёт
  type                String   // FIAT_DEPOSIT|FIAT_WITHDRAW|CROSS_BORDER|SBP
  status              String   @default("ACTIVE") // ACTIVE|INACTIVE|SUSPENDED
  priority            Int      @default(1) // 1=основной, 2=резервный
  logoUrl             String?
  contactPerson       String?
  contactPhone        String?
  contactEmail        String?
  contractDate        DateTime?
  contractExpiry      DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Регуляторные требования (ФЗ-1194918-8, 115-ФЗ, 152-ФЗ)
  licenseStatus       String?  // статус лицензии банка
  capitalRequirement  Float?   // требование к капиталу
  dataProcessorAgreement String? // договор обработки ПДн (152-ФЗ)

  // Технические (API интеграция)
  apiEndpoint         String?  // URL bank API
  apiProtocol         String   @default("REST") // REST|SOAP|GRAPHQL
  cryptoProtocol      String   @default("STANDARD_TLS") // GOST_TLS_1_3|STANDARD_TLS
  oauthServerUrl      String?
  oauthClientId       String?  // encrypted
  oauthClientSecret   String?  // encrypted
  merchantLogin       String?  // encrypted
  merchantPassword    String?  // encrypted
  signingCertificate  String?  // ЭП (CryptoPro) для ВТБ
  paymentPageMode     String   @default("API") // HOSTED|API
  isSandbox           Boolean  @default(true)

  // Вебхуки
  webhookUrl          String?  // URL для callback от банка
  webhookSecret       String?  // секрет для верификации

  fees                BankFee[]
  limits              BankLimit?
  accounts            BankAccount[]
  transactions        BankTransaction[]
  reconciliations     BankReconciliation[]
  webhookLogs         BankWebhookLog[]
  complianceExports   BankComplianceExport[]
  bankUsers           User[]
}

model BankFee {
  id              String   @id @default(cuid())
  bankId          String
  bank            Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  operationType   String   // DEPOSIT|WITHDRAW|CROSS_BORDER|SBP_TRANSFER
  feeType         String   // PERCENT|FIXED|COMBINED
  feePercent      Float    @default(0)
  feeFixed        Float    @default(0)
  feeMin          Float    @default(0)
  feeMax          Float?   // null = без максимума
  payer           String   @default("USER") // USER|EXCHANGE
  tiers           String?  // JSON: [{from,to,percent}]
  currency        String   @default("RUB")
  effectiveFrom   DateTime @default(now())
  effectiveTo     DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BankLimit {
  id                  String   @id @default(cuid())
  bankId              String   @unique
  bank                Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  dailyLimit          Float    @default(50000000) // 50M ₽
  monthlyLimit        Float    @default(500000000) // 500M ₽
  perTransactionLimit Float    @default(1000000) // 1M ₽
  perUserDailyLimit   Float    @default(300000) // 300K (115-ФЗ)
  currency            String   @default("RUB")
  alertThreshold      Float    @default(0.8) // 80%
  autoSuspendOnLimit  Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BankAccount {
  id            String   @id @default(cuid())
  bankId        String
  bank          Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  accountNumber String   // номер счёта
  currency      String   @default("RUB")
  balance       Float    @default(0) // из bank API
  minBalance    Float    @default(1000000) // alert threshold
  type          String   @default("CORRESPONDENT") // CORRESPONDENT|OPERATIONAL|RESERVE
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BankTransaction {
  id              String   @id @default(cuid())
  bankId          String
  bank            Bank     @relation(fields: [bankId], references: [id])
  transactionId   String?  // ссылка на внутреннюю Transaction
  userId          String?  // пользователь
  type            String   // DEPOSIT|WITHDRAW|CROSS_BORDER|SBP
  amount          Float    // сумма
  fee             Float    @default(0) // комиссия
  feePayer        String   @default("USER") // USER|EXCHANGE
  currency        String   @default("RUB")
  status          String   @default("PENDING") // PENDING|COMPLETED|FAILED|REVERSED|SUSPENDED_BY_BANK
  bankReference   String?  // ID транзакции в банке
  isThreshold     Boolean  @default(false) // >600K ₽ (115-ФЗ)
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BankReconciliation {
  id                  String   @id @default(cuid())
  bankId              String
  bank                Bank     @relation(fields: [bankId], references: [id])
  period              String   // "2026-06"
  statementFile       String?  // путь к файлу выписки
  totalTransactions   Int      @default(0)
  matchedCount        Int      @default(0)
  unmatchedInternal   Int      @default(0)
  unmatchedBank       Int      @default(0)
  status              String   @default("PENDING") // PENDING|IN_PROGRESS|MATCHED|DISCREPANCY
  discrepancyAmount   Float    @default(0)
  resolvedBy          String?
  resolvedAt          DateTime?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BankWebhookLog {
  id          String   @id @default(cuid())
  bankId      String
  bank        Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  eventType   String   // PAYMENT_STATUS_CHANGED|REFUND|REVERSAL|SUSPENDED
  payload     String   // JSON body
  processedAt DateTime?
  status      String   @default("RECEIVED") // RECEIVED|PROCESSED|FAILED
  createdAt   DateTime @default(now())
}

model BankComplianceExport {
  id          String   @id @default(cuid())
  bankId      String
  bank        Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  period      String   // "2026-06"
  format      String   // XML|CSV|JSON
  status      String   @default("PENDING") // PENDING|GENERATED|SENT
  fileUrl     String?
  requestedBy String?  // bank request reference
  createdAt   DateTime @default(now())
}

model CorridorConfig {
  id              String   @id @default(cuid())
  corridorId      String   @unique // "RU-CN"
  senderBankId    String?  // банк-отправитель (РФ)
  receiverBankId  String?  // банк-получатель (зарубежный)
  liquidityBridge String?  // партнёр конвертации
  feePercent      Float    @default(1.0)
  feeMin          Float    @default(0)
  feeMax          Float?
  etaMin          Int      @default(15) // минуты
  etaMax          Int      @default(40)
  minAmount       Float    @default(10000)
  maxAmount       Float    @default(10000000)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
